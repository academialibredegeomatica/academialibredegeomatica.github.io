---
import BaseLayout from "@components/base/BaseLayout.astro";
// Importamos el componente oficial para evitar conflictos
import { Image } from "astro:assets";

const { entry } = Astro.props;

// Verificación de seguridad: si no hay entrada, no renderizamos nada
if (!entry || !entry.data) return null;

const { title, image } = entry.data;
const { Content } = await entry.render();
---

<BaseLayout title={title}>
  <section class="py-12 bg-[#0f172a] min-h-screen">
    <div class="container mx-auto px-4 max-w-3xl">
      <h1 class="text-3xl font-bold text-white mb-6">{title}</h1>
      
      {image && (
        <div class="mb-8">
          <img 
            src={image} 
            alt={title || "Imagen del curso"} 
            class="w-full h-auto rounded-xl shadow-lg border border-white/5"
          />
        </div>
      )}

      <div class="prose prose-invert max-w-none text-slate-300 prose-headings:text-white prose-a:text-blue-400">
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>