---
import BaseLayout from "@components/base/BaseLayout.astro";
import { render } from 'astro:content';

const { entry } = Astro.props;

// Seguridad: Si no hay entrada, no renderizamos nada
if (!entry || !entry.data) return null;

const { title, image } = entry.data;
// Esta es la forma correcta y moderna de obtener el contenido en Astro
const { Content } = await render(entry);
---

<BaseLayout title={title}>
  <section class="py-12 bg-[#0f172a] min-h-screen">
    <div class="container mx-auto px-4 max-w-3xl">
      <h1 class="text-3xl font-bold text-white mb-6">{title}</h1>
      
      {image && (
        <div class="mb-8">
          <img 
            src={image} 
            alt={title || "Imagen de cabecera"} 
            class="w-full h-auto rounded-xl shadow-lg border border-white/5"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      <div class="prose prose-invert max-w-none text-slate-300">
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>