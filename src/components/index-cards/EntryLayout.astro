---
import BaseLayout from "@components/base/BaseLayout.astro";
const { entry } = Astro.props;

if (!entry || !entry.data) return Astro.redirect('/404');
const { title, image } = entry.data;
const { Content } = await entry.render();
---
<BaseLayout title={title}>
  <section class="py-16 bg-[#0f172a] min-h-screen">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-3xl font-bold text-white mb-8 border-l-4 border-blue-600 pl-4">{title}</h1>
      {image && <img src={image} alt={title} class="w-full h-auto rounded-2xl mb-8 shadow-2xl border border-white/10" />}
      <div class="prose prose-invert max-w-none prose-emerald">
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>