---
import BaseLayout from "@components/base/BaseLayout.astro";
import DocCard from "@components/docs/Card.astro";
import CourseCard from "@components/docs/CourseCard.astro";
import PageHeader from "@components/common/PageHeader.astro";
import type { DocsEntry } from "@/types";

interface Props {
  collectionIndex: DocsEntry;
  entries: DocsEntry[];
}

const { collectionIndex, entries } = Astro.props;
---

<BaseLayout
  title={collectionIndex.data.title}
  image={collectionIndex.data.image}
  description={collectionIndex.data.description}
>
  <PageHeader title={collectionIndex.data.title} />
  
  <section class="section py-12 bg-[#0f172a]">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap -mx-2">
        {
          entries.length > 0 ? (
            entries.map((entry) => {
              // Si el ID contiene "-index", renderizamos la tarjeta de categoría (DocCard)
              // Si NO lo contiene, es un curso individual y usamos CourseCard
              const isCategory = entry.id.includes("-index");

              return (
                <div class="w-full md:w-1/2 lg:w-1/3 p-2">
                  {isCategory ? (
                    <DocCard entry={entry} />
                  ) : (
                    <CourseCard entry={entry} />
                  )}
                </div>
              );
            })
          ) : (
            <div class="w-full text-center py-20">
              <p class="text-slate-400 text-lg italic">
                Aún no hay cursos disponibles en esta categoría.
              </p>
            </div>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>