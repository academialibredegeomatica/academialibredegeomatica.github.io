---
// Recibimos la entrada de la colección
const { entry } = Astro.props;

// Extraemos los datos con valores por defecto
const { 
  title = "Curso sin título", 
  empresa = "CAEG", 
  tipo = "Curso", 
  botonTexto = "ACCESO" 
} = entry.data || {};

// LÓGICA DE IMAGEN MEJORADA
const rawImage = entry.data?.image;
let imgSrc = "";

if (rawImage) {
  // Si es un objeto (de src/assets), extraemos la URL. Si es texto, lo usamos directo.
  imgSrc = typeof rawImage === 'object' ? rawImage.src : rawImage;
  
  // Limpieza de seguridad: Si la ruta no empieza con "/" y no es una URL externa, se lo ponemos.
  if (typeof imgSrc === 'string' && !imgSrc.startsWith('/') && !imgSrc.startsWith('http')) {
    imgSrc = '/' + imgSrc;
  }
}
---

<div class="h-full m-2 bg-[#0f172a] border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl group transition-all duration-300 hover:border-blue-500/50">
  
  <div class="relative aspect-video bg-slate-800 overflow-hidden flex items-center justify-center">
    {imgSrc ? (
      <img 
        src={imgSrc} 
        alt={title} 
        loading="eager"
        decoding="sync"
        class="object-cover w-full h-full opacity-100 group-hover:scale-110 transition-transform duration-700"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <div class="hidden flex-col items-center text-red-400 text-[10px] p-4 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 mb-1 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span class="font-bold">Error de ruta:</span>
        <code class="text-[8px] mt-1 bg-black/40 p-1 rounded break-all">{imgSrc}</code>
      </div>
    ) : (
      <div class="flex flex-col items-center text-slate-500 text-xs italic">
        <svg xmlns="http://www.w3.org/2000/astro" class="w-10 h-10 mb-2 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Sin imagen configurada
      </div>
    )}
    
    <div class="absolute top-3 right-3 z-10">
      <span class="bg-[#facc15] text-black text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-wider shadow-md">
        {tipo}
      </span>
    </div>
  </div>

  <div class="p-5 flex flex-col flex-grow bg-gradient-to-b from-slate-900/50 to-[#0f172a]">
    <h3 class="text-white font-bold text-base mb-4 leading-tight group-hover:text-blue-400 transition-colors min-h-[3rem]">
      {title}
    </h3>

    <div class="mb-5 flex flex-col items-center border-l-4 border-blue-600 bg-blue-900/20 p-3 rounded-r-lg">
      <span class="text-[9px] text-blue-400 font-black uppercase tracking-widest mb-1">Certifica:</span>
      <span class="text-white text-sm font-bold text-center">{empresa}</span>
    </div>

    <div class="mt-auto">
      <div class="w-full text-center bg-[#2563eb] hover:bg-blue-500 text-white text-xs font-black py-3 rounded-xl border-b-4 border-blue-800 shadow-lg active:translate-y-1 active:border-b-0 transition-all cursor-pointer uppercase">
        {botonTexto}
      </div>
    </div>
  </div>
</div>

<style>
  .h-full { min-height: 420px; }
</style>