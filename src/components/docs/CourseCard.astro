---
const { entry } = Astro.props;
if (!entry) return null;

const data = entry.data || {};
const title = data.title || "Curso";
const image = data.image || "";
const urlDestino = data.url_destino; // Tu link de YouTube

// Ruta interna por si no hay link externo
const urlInterna = `/docs/${entry.id.replace(".md", "").replace("/-index", "")}`;

const destinoFinal = urlDestino || urlInterna;
const esExterno = String(destinoFinal).startsWith('http');
---

<div class="h-full m-2 bg-[#0f172a] border border-white/10 rounded-2xl overflow-hidden flex flex-col group transition-all duration-300 hover:border-blue-500/50">
  <div class="relative aspect-video bg-slate-800 flex items-center justify-center p-2">
    {image ? (
      <img 
        src={image} 
        alt={title} 
        class="object-contain w-full h-full"
      />
    ) : (
      <div class="text-slate-500 text-xs italic">Sin imagen</div>
    )}
  </div>

  <div class="p-5 flex flex-col flex-grow">
    <h3 class="text-white font-bold text-base mb-4 leading-tight">
      {title}
    </h3>

    <div class="mt-auto">
      <a 
        href={destinoFinal}
        target={esExterno ? "_blank" : "_self"}
        rel={esExterno ? "noopener noreferrer" : ""}
        class="block w-full text-center bg-[#2563eb] hover:bg-blue-500 text-white text-xs font-bold py-3 rounded-xl uppercase no-underline shadow-lg"
      >
        {urlDestino ? "VER VIDEO" : "ACCESO"}
      </a>
    </div>
  </div>
</div>