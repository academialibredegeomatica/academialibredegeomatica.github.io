---
import type { DocsEntry } from "@/types";
import { Image } from "astro:assets";

interface Props {
  entry: DocsEntry;
}

const { entry } = Astro.props;
// Extraemos los datos del entry.data
const { title, image, empresa, tipo, botonTexto } = entry.data;
---

<div class="h-full m-2 bg-[#0f172a] border border-white/20 rounded-2xl overflow-hidden flex flex-col shadow-2xl">
  
  <div class="relative aspect-video bg-black">
    {image && (
      <Image
        class="object-cover w-full h-full opacity-90"
        src={image}
        alt={title}
        width={1280}
        height={720}
      />
    )}
    
    {tipo && (
      <div class="absolute top-2 right-2 z-20">
        <span class="bg-yellow-400 text-black text-[10px] font-black px-3 py-1 rounded-full uppercase">
          {tipo}
        </span>
      </div>
    )}
  </div>

  <div class="p-5 flex flex-col flex-grow">
    <h3 class="text-white font-bold text-lg mb-4 leading-tight">
      {title}
    </h3>

    {empresa && (
      <div class="mb-5 border-l-4 border-blue-500 bg-white/5 p-3 rounded-r-lg">
        <p class="text-[10px] text-blue-400 font-black uppercase mb-1">Certifica:</p>
        <p class="text-white text-sm font-bold">{empresa}</p>
      </div>
    )}

    <div class="mt-auto">
      <div class="w-full text-center bg-blue-600 text-white text-xs font-black py-3 rounded-xl border-b-4 border-blue-800">
        {botonTexto || "ACCESO"}
      </div>
    </div>
  </div>
</div>