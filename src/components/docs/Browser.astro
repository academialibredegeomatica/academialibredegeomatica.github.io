---
import { getCollection } from 'astro:content';

const allDocs = await getCollection('docs');
// Protección: Si no hay documentos, devolvemos un array vacío
const docs = allDocs || [];

// Lógica para organizar el explorador de archivos
const folders = [...new Set(docs.map(doc => doc.id.split('/')[0]))];
---

<div class="bg-slate-900/50 rounded-xl p-4 border border-white/10">
  <h4 class="text-white font-bold mb-4 text-sm uppercase tracking-widest">Explorador</h4>
  <ul class="space-y-2">
    {folders && folders.length > 0 ? folders.map(folder => (
      <li>
        <details class="group">
          <summary class="text-slate-300 hover:text-white cursor-pointer list-none flex items-center gap-2 text-sm">
            <span class="transition-transform group-open:rotate-90">▶</span>
            📁 {folder}
          </summary>
          <ul class="ml-6 mt-2 space-y-1 border-l border-white/5 pl-2">
            {docs
              .filter(doc => doc.id.startsWith(folder) && !doc.id.includes('-index'))
              .map(doc => (
                <li>
                  <a 
                    href={`/docs/${doc.id.replace('.md', '')}`}
                    class="text-slate-400 hover:text-sky-400 text-xs transition-colors"
                  >
                    📄 {doc.data.title || doc.id}
                  </a>
                </li>
              ))
            }
          </ul>
        </details>
      </li>
    )) : (
      <li class="text-slate-500 text-xs italic">No hay carpetas disponibles</li>
    )}
  </ul>
</div>