---
import { getCollection, getEntry } from 'astro:content';
import CollectionLayout from "@components/docs/CollectionLayout.astro";
import EntryLayout from "@components/docs/EntryLayout.astro";
import type { DocsEntry } from "@/types";

export async function getStaticPaths() {
  const allEntries = await getCollection('docs');
  
  return allEntries.map(entry => {
    // 1. Limpiamos el ID de extensiones y del sufijo -index
    const cleanId = entry.id.replace(/\.md$/, "").replace("/-index", "");
    
    // 2. Determinamos si es un grupo (categoría) o un curso individual
    const isGroup = entry.id.includes("-index");

    return {
      params: { id: cleanId },
      props: { entry, isGroup },
    };
  });
}

const { entry, isGroup } = Astro.props;

// Lógica para obtener los hijos si es un grupo
let groupEntries: DocsEntry[] = [];
if (isGroup) {
  const allDocs = await getCollection('docs');
  // Obtenemos el nombre de la carpeta (ej: "Gestion del riesgo")
  const folderName = entry.id.split('/')[0];
  
  // Filtramos: que estén en la misma carpeta y que NO sean el índice
  groupEntries = allDocs.filter(item => 
    item.id.startsWith(folderName) && !item.id.includes("-index")
  ) as DocsEntry[];

  // Ordenamos por weight
  groupEntries.sort((a, b) => (a.data.weight ?? 99) - (b.data.weight ?? 99));
}
---

{isGroup ? (
  <CollectionLayout collectionIndex={entry} entries={groupEntries} />
) : (
  <EntryLayout entry={entry} />
)}