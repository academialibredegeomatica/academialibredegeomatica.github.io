---
import { getCollection } from 'astro:content';
import CollectionLayout from "@components/docs/CollectionLayout.astro";
import EntryLayout from "@components/docs/EntryLayout.astro";

// 1. GENERACIÓN DE RUTAS DINÁMICAS
export async function getStaticPaths() {
  const allEntries = await getCollection('docs');
  
  return allEntries.flatMap(entry => {
    // Generamos varias opciones de ID para que el navegador siempre encuentre el archivo
    const idSinExtension = entry.id.replace(/\.md$/, '');
    
    // Versión limpia (slug): minúsculas, sin espacios, sin caracteres raros
    const idSlug = idSinExtension
      .toLowerCase()
      .replace(/\s+/g, '-')     
      .replace(/[^\w-]/g, '');  

    return [
      { params: { id: entry.id }, props: { entry } },       // Opción 1: original (con .md)
      { params: { id: idSinExtension }, props: { entry } }, // Opción 2: sin .md
      { params: { id: idSlug }, props: { entry } }         // Opción 3: limpia (slug)
    ];
  });
}

// 2. PROCESAMIENTO DE LA ENTRADA ACTUAL
const { entry } = Astro.props;

// Corrección: Detectamos si es una carpeta (índice) de forma flexible
const isGroup = entry.id.toLowerCase().includes("index");

let groupEntries = [];
if (isGroup) {
  const allDocs = await getCollection('docs');
  // Obtenemos el nombre de la carpeta contenedora
  const folderName = entry.id.split('/')[0];
  
  // Filtramos los archivos de esa carpeta que NO sean el índice
  groupEntries = allDocs.filter(item => 
    item.id.startsWith(folderName) && !item.id.toLowerCase().includes("index")
  );
  
  // Opcional: Ordenar alfabéticamente por título
  groupEntries.sort((a, b) => (a.data.title || "").localeCompare(b.data.title || ""));
}
---

{isGroup ? (
  <CollectionLayout collectionIndex={entry} entries={groupEntries} />
) : (
  <EntryLayout entry={entry} />
)}