---
import type { DocsEntry, MenuItem } from "@/types";
import EntryLayout from "@components/docs/EntryLayout.astro";
import CollectionLayout from "@components/docs/CollectionLayout.astro";
import { getEntries, getEntriesInGroup, getGroups } from "@lib/contentParser";
import { sortByTitle } from "@lib/sortFunctions";

export async function getStaticPaths() {
  const entries = (await getEntries("docs", sortByTitle)) as DocsEntry[];

  return entries.map((entry) => {
    // Detectamos si es una categoría principal
    const isGroup = entry.id.includes("-index");
    
    // TRUCO DE COMPATIBILIDAD: 
    // Dejamos el ".md" en la URL para que coincida con el enlace de tus tarjetas
    const idParam = isGroup 
      ? entry.id.replace("/-index", "") 
      : entry.id;

    return {
      params: { id: idParam },
      props: { entry, isGroup },
    };
  });
}

const { entry, isGroup } = Astro.props;

// Extraemos el nombre EXACTO de la carpeta (ignorando lo que haya después de la barra)
// Ejemplo: "Gestion del Riesgo/-index.md" -> se queda solo con "Gestion del Riesgo"
const groupName = entry.id.split('/')[0];

// Buscamos todos los cursos hijos que pertenezcan a esa carpeta
const groupEntries = isGroup
  ? ((await getEntriesInGroup("docs", groupName, sortByTitle)) as DocsEntry[])
  : [];

// Construcción del Menú Lateral
const browserMenu: MenuItem[] = [];
const groups = (await getGroups("docs", sortByTitle)) as DocsEntry[];

await Promise.all(
  groups.map(async (group) => {
    const cleanGroupId = group.id.replace("/-index", "");
    const subEntries = (await getEntriesInGroup(
      "docs",
      group.id.split('/')[0],
      sortByTitle
    )) as DocsEntry[];
    
    browserMenu.push({
      title: group.data.title,
      id: cleanGroupId,
      children: subEntries.map((subEntry) => ({
        title: subEntry.data.title,
        id: subEntry.id,
        children: [],
      })),
    });
  })
);
---

{
  isGroup ? (
    <CollectionLayout collectionIndex={entry} entries={groupEntries} />
  ) : (
    <EntryLayout entry={entry} browserMenu={browserMenu} />
  )
}