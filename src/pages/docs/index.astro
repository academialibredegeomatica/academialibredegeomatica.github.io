---
import { getCollection, getEntry } from 'astro:content';
import CollectionLayout from "@components/docs/CollectionLayout.astro";

// 1. Traemos el índice general de la colección (Ahora es 'index' sin guion)
const collectionIndex = await getEntry('docs', 'index');

/**
 * 2. FILTRO MAESTRO ACTUALIZADO:
 * Buscamos archivos que estén en carpetas y se llamen 'index'.
 * Esto filtrará tus categorías principales (las 10 que quieres mostrar).
 */
const allGroups = await getCollection('docs', (entry) => {
  // Filtramos para que incluya archivos que sean 'index' dentro de carpetas
  // Ejemplo: "gestion-del-riesgo/index"
  return entry.id.endsWith('index') || entry.id.endsWith('index.md');
});

// 3. Filtramos para NO incluir el index principal en la lista de tarjetas
// (No queremos que la página de cursos se muestre a sí misma como un curso)
const filteredGroups = allGroups.filter(group => group.id !== 'index' && group.id !== 'index.md');

// 4. Ordenamos por el campo 'weight' definido en el Markdown
const groupIndices = filteredGroups.sort((a, b) => {
  const weightA = a.data.weight ?? 99;
  const weightB = b.data.weight ?? 99;
  return weightA - weightB;
});
---

<CollectionLayout collectionIndex={collectionIndex} entries={groupIndices} />