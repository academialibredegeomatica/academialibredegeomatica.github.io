---
// Si el index.astro funciona, esta línea tiene que funcionar por fuerza
import Base from "@/layouts/Base.astro";
---

<Base title="Biblioteca Geomática">
  <div style="padding: 100px 20px; text-align: center; background: rgba(0,0,0,0.5); border-radius: 20px; margin: 50px;">
    <h1 style="color: white; font-size: 3rem; font-weight: bold; margin-bottom: 20px;">
      📚 Biblioteca Digital
    </h1>
    <p style="color: #cbd5e1; font-size: 1.2rem;">
      Si estás viendo este texto sobre el fondo oscuro de la web, ¡hemos vencido al error!
    </p>
    
    <div style="display: grid; grid-template-cols: 1fr 1fr; gap: 20px; margin-top: 40px;">
       <div style="border: 2px solid #3b82f6; padding: 20px; border-radius: 15px; color: white;">
          <h2>📍 SIG</h2>
       </div>
       <div style="border: 2px solid #10b981; padding: 20px; border-radius: 15px; color: white;">
          <h2>🛰️ Teledetección</h2>
       </div>
    </div>
  </div>
</Base>