---
// ¡La ruta correcta por fin!
import BaseLayout from "@components/base/BaseLayout.astro";

const title = "Biblioteca Digital";
const description = "Colección de recursos especializados en Geomática, SIG y Teledetección.";

const categorias = [
  { id: "sig", titulo: "Sistemas de Información Geográfica", color: "border-blue-500", icon: "📍", desc: "Software, análisis espacial y gestión de datos vectoriales." },
  { id: "tele", titulo: "Teledetección y Fotogrametría", color: "border-green-500", icon: "🛰️", desc: "Procesamiento de imágenes satelitales, drones y LiDAR." },
  { id: "carto", titulo: "Cartografía y Geodesia", color: "border-yellow-500", icon: "🗺️", desc: "Sistemas de referencia, proyecciones y diseño de mapas." }
];
---

<BaseLayout title={title} description={description}>
  <section class="py-16 bg-[#0f172a] min-h-screen">
    <div class="container mx-auto px-4 max-w-5xl">
      
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight border-b border-blue-500 pb-8 inline-block">
          {title}
        </h1>
        <p class="text-slate-300 text-lg max-w-2xl mx-auto">
          Explora nuestra colección de recursos organizados por especialidad.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-24">
        {categorias.map((cat) => (
          <a href={`#${cat.id}`} class={`p-8 rounded-2xl border border-white/10 hover:${cat.color} bg-white/5 backdrop-blur-sm text-center transition-all hover:scale-105 hover:bg-white/10 group`}>
            <div class="text-6xl mb-6 group-hover:scale-110 transition-transform">{cat.icon}</div>
            <h3 class="text-2xl font-bold text-white mb-3">{cat.titulo}</h3>
            <p class="text-slate-400 text-sm">{cat.desc}</p>
          </a>
        ))}
      </div>

      <div class="space-y-16">
        {categorias.map((cat) => (
          <div id={cat.id} class="scroll-mt-24">
            <div class="flex items-center mb-6 border-b border-white/10 pb-4">
              <span class="text-3xl mr-4">{cat.icon}</span>
              <h2 class="text-2xl md:text-3xl font-bold text-white">{cat.titulo}</h2>
            </div>
            <div class="p-10 bg-white/5 rounded-xl border border-white/10 border-dashed text-center">
               <p class="text-slate-400 italic">Aquí insertaremos la base de datos de los 1,000 libros...</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>