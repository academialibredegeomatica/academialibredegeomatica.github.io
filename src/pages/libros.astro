---
// Esta ruta sube desde pages hasta src y entra a layouts. Es infalible.
import Base from "../layouts/Base.astro";

const categorias = [
  {
    id: "sig",
    titulo: "Sistemas de Información Geográfica",
    desc: "Software, análisis espacial y gestión de datos.",
    color: "border-blue-500",
    icon: "📍"
  },
  {
    id: "tele",
    titulo: "Teledetección",
    desc: "Imágenes satelitales y drones.",
    color: "border-green-500",
    icon: "🛰️"
  }
];
---

<Base title="Biblioteca">
  <main class="container mx-auto py-20 px-4 text-center">
    <h1 class="text-5xl font-bold text-white mb-10">Biblioteca Digital</h1>
    
    <div class="grid md:grid-cols-2 gap-8">
      {categorias.map((cat) => (
        <div class={`p-10 rounded-2xl border-2 ${cat.color} bg-black/50 backdrop-blur-md`}>
          <div class="text-7xl mb-4">{cat.icon}</div>
          <h2 class="text-2xl font-bold text-white">{cat.titulo}</h2>
          <p class="text-slate-400 mt-2">{cat.desc}</p>
        </div>
      ))}
    </div>
  </main>
</Base>