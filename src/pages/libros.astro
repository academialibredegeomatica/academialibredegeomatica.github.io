---
import BaseLayout from "@components/base/BaseLayout.astro";
// Importamos tu lista de 131 libros
import librosData from "../data/libros.json"; 

const title = "Biblioteca Digital";
const description = "Recursos especializados en Geomática, SIG y Teledetección.";

const categorias = [
  { id: "sig", titulo: "Sistemas de Información Geográfica", color: "text-blue-400", bg: "bg-blue-400/10", icon: "📍" },
  { id: "tele", titulo: "Teledetección y Fotogrametría", color: "text-green-400", bg: "bg-green-400/10", icon: "🛰️" },
  { id: "carto", titulo: "Cartografía y Geodesia", color: "text-yellow-400", bg: "bg-yellow-400/10", icon: "🗺️" }
];
---

<BaseLayout title={title} description={description}>
  <section class="py-16 bg-[#0f172a] min-h-screen">
    <div class="container mx-auto px-4 max-w-5xl">
      
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{title}</h1>
        <p class="text-slate-400">Total: {librosData.length} recursos disponibles</p>
      </div>

      {categorias.map((cat) => (
        <div id={cat.id} class="mb-16 scroll-mt-24">
          <div class={`flex items-center gap-4 p-4 rounded-xl ${cat.bg} mb-6 border border-white/5`}>
            <span class="text-3xl">{cat.icon}</span>
            <h2 class={`text-2xl font-bold ${cat.color}`}>{cat.titulo}</h2>
          </div>

          <div class="grid gap-2">
            {librosData
              .filter(libro => libro.Categoria === cat.id)
              .map((libro) => (
                <div class="flex items-center justify-between p-3 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 transition-all group">
                  <div class="flex items-center gap-3 overflow-hidden">
                    <span class="text-slate-500 group-hover:text-blue-400 flex-shrink-0">📚</span>
                    <span class="text-slate-200 text-sm md:text-base truncate" title={libro.Titulo}>
                      {libro.Titulo.replace(/_/g, ' ')}
                    </span>
                  </div>
                  <a 
                    href={libro.Link_Drive} 
                    target="_blank" 
                    class="flex-shrink-0 ml-4 text-xs bg-slate-700 hover:bg-blue-600 text-white py-1.5 px-4 rounded-md transition-colors"
                  >
                    Descargar
                  </a>
                </div>
              ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>