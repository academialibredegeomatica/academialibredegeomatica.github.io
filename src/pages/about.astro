echo '---
import { getEntry } from "astro:content";
import EntryLayout from "@components/about/EntryLayout.astro";

const entry = await getEntry("about", "index");

if (!entry) {
  throw new Error("No se encontró el archivo src/content/about/index.md");
}
---

<EntryLayout entry={entry} />' > src/pages/about.astro && git add src/pages/about.astro && git commit -m "Forzando uso de getEntry en about.astro" && git push origin main