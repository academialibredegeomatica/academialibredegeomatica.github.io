---
import { getEntry } from 'astro:content';
import EntryLayout from "@components/about/EntryLayout.astro";

// Vamos directo al archivo 'index' dentro de la carpeta 'about'
const entry = await getEntry('about', 'index');

if (!entry) {
  throw new Error("No se encontró el archivo src/content/about/index.md");
}
---

<EntryLayout entry={entry} />